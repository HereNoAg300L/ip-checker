{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ip-checker",
  "main": "./src/index.js",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
